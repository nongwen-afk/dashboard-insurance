# Server-only Neon/Postgres connection string.
# Local and preview/non-prod environments must point to a non-production database.
# Production must use its own production-scoped value in Vercel.
DATABASE_URL="postgres://user:password@host.neon.tech/database?sslmode=require"

# Public, non-secret environment label used by the app/diagnostics.
# Expected values: local, test, preview, staging, production.
NEXT_PUBLIC_APP_ENV="local"

# Sentry runtime monitoring. The DSN is safe to expose to browser code.
# Leave it empty to disable Sentry locally.
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry build credentials used only for release/source map upload.
# Configure these as protected Vercel environment variables.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
